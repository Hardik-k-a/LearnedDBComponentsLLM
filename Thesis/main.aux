\@writefile{lof}{\contentsline {figure}{\numberline {7.1}{\ignorespaces Entity-relationship diagram of the IMDB database schema. The \texttt  {title\_principals} table acts as a central junction connecting titles to people, while \texttt  {title\_ratings} provides aggregate user feedback per title. These relationships define the valid join paths for generated queries.}}{28}{figure.caption.13}\protected@file@percent }
\newlabel{fig:imdb_schema}{{7.1}{28}{Entity-relationship diagram of the IMDB database schema. The \texttt {title\_principals} table acts as a central junction connecting titles to people, while \texttt {title\_ratings} provides aggregate user feedback per title. These relationships define the valid join paths for generated queries}{figure.caption.13}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7.1}{\ignorespaces Experimental configuration parameters.}}{28}{table.caption.14}\protected@file@percent }
\newlabel{tab:exp_config}{{7.1}{28}{Experimental configuration parameters}{table.caption.14}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7.2}{\ignorespaces Structural feature distributions across the generated workload. The balanced coverage of different table counts, join complexities, and predicate counts confirms that the diversity hint mechanism prevents the LLM from converging on a narrow subset of query patterns.}}{29}{figure.caption.15}\protected@file@percent }
\newlabel{fig:structural_analysis}{{7.2}{29}{Structural feature distributions across the generated workload. The balanced coverage of different table counts, join complexities, and predicate counts confirms that the diversity hint mechanism prevents the LLM from converging on a narrow subset of query patterns}{figure.caption.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7.3}{\ignorespaces Query validation success rates across the four filtering layers. The high pass rate at each stage demonstrates the effectiveness of the prompt engineering constraints in guiding the LLM toward valid query structures.}}{29}{figure.caption.16}\protected@file@percent }
\newlabel{fig:validation_results}{{7.3}{29}{Query validation success rates across the four filtering layers. The high pass rate at each stage demonstrates the effectiveness of the prompt engineering constraints in guiding the LLM toward valid query structures}{figure.caption.16}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7.4}{\ignorespaces Distribution of table count per query. The weighted mix of single-table, two-table, and three-table queries ensures coverage of both simple selections and complex multi-way joins.}}{30}{figure.caption.17}\protected@file@percent }
\newlabel{fig:tables_distribution}{{7.4}{30}{Distribution of table count per query. The weighted mix of single-table, two-table, and three-table queries ensures coverage of both simple selections and complex multi-way joins}{figure.caption.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7.5}{\ignorespaces Distribution of predicate count per query. The majority of queries contain one to three predicates, reflecting a realistic range of filter complexities.}}{30}{figure.caption.17}\protected@file@percent }
\newlabel{fig:predicates_distribution}{{7.5}{30}{Distribution of predicate count per query. The majority of queries contain one to three predicates, reflecting a realistic range of filter complexities}{figure.caption.17}{}}
\@writefile{toc}{\contentsline {section}{\numberline {7.3}Active Learning and Model Training Results}{30}{section.7.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7.6}{\ignorespaces Distribution of join conditions per query. Queries with zero joins correspond to single-table queries, while one and two join conditions correspond to two-table and three-table queries, respectively.}}{31}{figure.caption.18}\protected@file@percent }
\newlabel{fig:joins_distribution}{{7.6}{31}{Distribution of join conditions per query. Queries with zero joins correspond to single-table queries, while one and two join conditions correspond to two-table and three-table queries, respectively}{figure.caption.18}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7.7}{\ignorespaces Distribution of true cardinalities ($\log _{10}$ scale). The wide range spanning several orders of magnitude forces the model to learn accurate estimates for both highly selective queries returning few rows and broad queries spanning millions of tuples.}}{31}{figure.caption.19}\protected@file@percent }
\newlabel{fig:cardinality_dist}{{7.7}{31}{Distribution of true cardinalities ($\log _{10}$ scale). The wide range spanning several orders of magnitude forces the model to learn accurate estimates for both highly selective queries returning few rows and broad queries spanning millions of tuples}{figure.caption.19}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7.8}{\ignorespaces Active learning curve showing validation median Q-error versus the number of labeled queries. The steep initial decline demonstrates rapid learning from the first few rounds, while the flattening tail indicates diminishing returns as the model approaches its capacity on the given data.}}{32}{figure.caption.20}\protected@file@percent }
\newlabel{fig:learning_curves_comparison}{{7.8}{32}{Active learning curve showing validation median Q-error versus the number of labeled queries. The steep initial decline demonstrates rapid learning from the first few rounds, while the flattening tail indicates diminishing returns as the model approaches its capacity on the given data}{figure.caption.20}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7.9}{\ignorespaces Training loss curves across active learning rounds. The consistently decreasing trajectory demonstrates stable convergence, with each round starting from a better baseline than the previous one due to the expanded and more informative training set.}}{32}{figure.caption.21}\protected@file@percent }
\newlabel{fig:training_loss_rounds}{{7.9}{32}{Training loss curves across active learning rounds. The consistently decreasing trajectory demonstrates stable convergence, with each round starting from a better baseline than the previous one due to the expanded and more informative training set}{figure.caption.21}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7.10}{\ignorespaces Predicted vs.\ actual cardinality on a log-log scale. The concentration of points along the diagonal indicates that the MSCN model produces well-calibrated estimates across the full cardinality range, from selective single-table queries to large multi-table joins.}}{33}{figure.caption.22}\protected@file@percent }
\newlabel{fig:pred_vs_actual}{{7.10}{33}{Predicted vs.\ actual cardinality on a log-log scale. The concentration of points along the diagonal indicates that the MSCN model produces well-calibrated estimates across the full cardinality range, from selective single-table queries to large multi-table joins}{figure.caption.22}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7.11}{\ignorespaces Cumulative distribution function of Q-errors. The steep rise at low Q-error values indicates that the majority of queries are estimated within a factor of 2--5 of their true cardinality.}}{34}{figure.caption.23}\protected@file@percent }
\newlabel{fig:qerror_cdf}{{7.11}{34}{Cumulative distribution function of Q-errors. The steep rise at low Q-error values indicates that the majority of queries are estimated within a factor of 2--5 of their true cardinality}{figure.caption.23}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7.12}{\ignorespaces Q-error box plots per active learning round. The narrowing boxes and decreasing medians demonstrate how each round improves estimation accuracy.}}{34}{figure.caption.23}\protected@file@percent }
\newlabel{fig:qerror_boxplot}{{7.12}{34}{Q-error box plots per active learning round. The narrowing boxes and decreasing medians demonstrate how each round improves estimation accuracy}{figure.caption.23}{}}
\@writefile{toc}{\contentsline {section}{\numberline {7.4}Labeling Efficiency Analysis}{34}{section.7.4}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {7.5}Comparison with PostgreSQL Optimizer}{34}{section.7.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7.13}{\ignorespaces Q-error statistics across active learning rounds. The consistent decrease in all percentile metrics confirms that active query selection improves not only typical-case accuracy but also tail-end performance on the most challenging queries.}}{35}{figure.caption.24}\protected@file@percent }
\newlabel{fig:qerror_stats}{{7.13}{35}{Q-error statistics across active learning rounds. The consistent decrease in all percentile metrics confirms that active query selection improves not only typical-case accuracy but also tail-end performance on the most challenging queries}{figure.caption.24}{}}
\@writefile{toc}{\contentsline {section}{\numberline {7.6}Discussion}{35}{section.7.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7.14}{\ignorespaces Labeling efficiency comparison. The active learning approach achieves competitive accuracy with significantly fewer labeled queries than a fully supervised baseline, demonstrating that intelligent query selection reduces the dominant cost factor in the pipeline.}}{36}{figure.caption.25}\protected@file@percent }
\newlabel{fig:labeling_efficiency}{{7.14}{36}{Labeling efficiency comparison. The active learning approach achieves competitive accuracy with significantly fewer labeled queries than a fully supervised baseline, demonstrating that intelligent query selection reduces the dominant cost factor in the pipeline}{figure.caption.25}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7.15}{\ignorespaces Labeling success rate across the pipeline. Queries that exceed the database timeout are assigned fallback cardinalities. The high success rate confirms that the generated queries are overwhelmingly executable within the configured time limits.}}{37}{figure.caption.26}\protected@file@percent }
\newlabel{fig:labeling_rate}{{7.15}{37}{Labeling success rate across the pipeline. Queries that exceed the database timeout are assigned fallback cardinalities. The high success rate confirms that the generated queries are overwhelmingly executable within the configured time limits}{figure.caption.26}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7.16}{\ignorespaces Q-error CDF comparing the MSCN model against PostgreSQL's native estimator. A curve shifted further left indicates better estimation accuracy.}}{37}{figure.caption.27}\protected@file@percent }
\newlabel{fig:pg_cdf}{{7.16}{37}{Q-error CDF comparing the MSCN model against PostgreSQL's native estimator. A curve shifted further left indicates better estimation accuracy}{figure.caption.27}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7.17}{\ignorespaces Predicted vs.\ actual scatter comparing MSCN and PostgreSQL. Points closer to the diagonal represent more accurate estimates.}}{37}{figure.caption.27}\protected@file@percent }
\newlabel{fig:pg_scatter}{{7.17}{37}{Predicted vs.\ actual scatter comparing MSCN and PostgreSQL. Points closer to the diagonal represent more accurate estimates}{figure.caption.27}{}}
